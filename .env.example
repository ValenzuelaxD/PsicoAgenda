VITE_API_URL=https://psicoagenda-api-315439788368.us-central1.run.app

# Notifications polling intervals (milliseconds)
# Desktop default: 45000
VITE_NOTIF_POLL_DESKTOP_MS=45000

# Mobile default: 75000
VITE_NOTIF_POLL_MOBILE_MS=75000

# Minimum time between automatic notification toasts (milliseconds)
# Default: 30000
VITE_NOTIF_TOAST_COOLDOWN_MS=30000

# Appointment windows by role (days)
VITE_APPOINTMENT_WINDOW_PATIENT_DAYS=45
VITE_APPOINTMENT_WINDOW_PSYCHOLOGIST_DAYS=180

# Backend validation windows by role (days)
MAX_BOOKING_DAYS_PACIENTE=45
MAX_BOOKING_DAYS_PSICOLOGA=180
