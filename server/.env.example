PORT=8080
DB_USER=tu_usuario_db
DB_HOST=tu_host_db
DB_DATABASE=tu_basedatos
DB_PASSWORD=tu_password_db
DB_PORT=5432
JWT_SECRET=tu_jwt_secret_seguro
# PostgreSQL connection details
# Replace these with your local PostgreSQL database credentials
# For Google Cloud SQL, update DB_HOST with your Cloud SQL instance connection name

# Database user (default: PsicoAgenda)
DB_USER=PsicoAgenda

# Database host (localhost for local dev, or Cloud SQL instance for production)
DB_HOST=localhost

# Database name
DB_DATABASE=psicoagenda

# Database password
DB_PASSWORD=your_password_here

# Database port (default PostgreSQL port)
DB_PORT=5432

# Server port (port where the backend will run)
PORT=3001

# JWT Secret (IMPORTANT: Use a strong random string, minimum 32 characters)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
